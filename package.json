{
  "version": "0.1.1",
  "name": "simple-local-ai-completion",
  "displayName": "Simple Local AI: Completion",
  "description": "Local LLM-powered inline code completions for VS Code.",
  "publisher": "sixty-four-pages",
  "categories": [
    "Other"
  ],
  "scripts": {
    "build": "vsce package --allow-missing-repository -o ./build/"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./src/extension.js",
  "configurationDefaults": {
    "editor.inlineSuggest.enabled": true,
    "editor.suggest.snippetsPreventQuickSuggestions": false
  },
  "contributes": {
    "commands": [
      {
        "command": "simple-local-ai.completion.selectPreset",
        "title": "Simple Local AI: Completion: Select Preset"
      }
    ],
    "configuration": {
      "title": "Simple Local AI: Completion",
      "properties": {
        "simple-local-ai.completion.main.debounceMs": {
          "type": "number",
          "default": 400,
          "description": "Задержка перед запросом (мс)"
        },
        "simple-local-ai.completion.main.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Включить/выключить генерацию кода"
        },
        "simple-local-ai.completion.main.enabledLogging": {
          "type": "boolean",
          "default": false,
          "description": "Включить лог запросов. Файл ai_debug.log будет создан в папке данных расширения"
        },
        "simple-local-ai.completion.main.presetSelected": {
          "type": "string",
          "default": "Qwen 2.5 Coder",
          "markdownDescription": "Текущий активный профиль. [Выбрать из списка...](command:simple-local-ai.completion.selectPreset)"
        },
        "simple-local-ai.completion.main.presetSyncronize": {
          "type": "boolean",
          "default": true,
          "description": "Автоматически перезагружать пресеты при изменении внешнего файла"
        },

        "simple-local-ai.completion.model.endpoint": {
          "type": "string",
          "default": "http://localhost:8081/completion",
          "description": "URL-адрес API для запросов"
        },
        "simple-local-ai.completion.model.parameters": {
          "type": "object",
          "description": "Дополнительные параметры модели: temperature, top_p, top_k, n_predict...",
          "additionalProperties": { "type": "number" },
          "default": {
            "temperature": 0.2,
            "n_predict": 64,
            "top_p": 0.9,
            "top_k": 40
          }
        },
        "simple-local-ai.completion.model.promptTemplate": {
          "type": "string", 
          "editPresentation": "multilineText",
          "description": "Шаблон запроса с переменными {prefix} и {suffix}",
          "default": "<|file_separator|>// Path: {relativePath}\n// Language: {lang}\n<|fim_prefix|>{prefix}<|fim_suffix|>{suffix}<|fim_middle|>"
        },
        "simple-local-ai.completion.model.requestHeaders": {
          "type": "object",
          "description": "Дополнительные HTTP-заголовки для запросов к API",
          "additionalProperties": {
            "type": "string"
          }
        },
        "simple-local-ai.completion.model.values.prefixLength": {
            "type": "number",
            "default": 1000,
            "description": "Размер выборки текста перед курсором"
         },
        "simple-local-ai.completion.model.values.suffixLength": {
          "type": "number",
          "default": 500,
          "description": "Размер выборки текста после курсора"
        }
      }
    }
  }
}
